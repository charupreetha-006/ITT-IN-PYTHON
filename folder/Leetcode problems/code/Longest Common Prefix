class Solution:
    def longestCommonPrefix(self, strs: List[str]) -> str:
        pref = strs[0]
        length = len(pref)

        for s in strs[1:]:
            while pref != s[0:length]:
                length -= 1
                if length == 0:
                    return ""
                
                pref = pref[0:length]
        
        return pref
